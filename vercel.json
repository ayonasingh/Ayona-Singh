{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "react-portfolio/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "react-portfolio/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/react-portfolio/dist/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
